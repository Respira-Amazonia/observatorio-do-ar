# =============================================================
# Observatório do Ar — variáveis de ambiente
# Copie este arquivo para .env e preencha com valores reais.
# O arquivo .env NUNCA deve ser versionado.
# =============================================================

# PostgreSQL
POSTGRES_DB=observatorio
POSTGRES_USER=TROQUE_O_USUARIO
POSTGRES_PASSWORD=TROQUE_A_SENHA

# Subscriber MQTT
# O username deve corresponder ao username_mqtt cadastrado no banco.
# A senha deve corresponder ao token armazenado via crypt() no seed ou init de produção.
MQTT_SUBSCRIBER_USERNAME=sistema_ingestao
MQTT_SUBSCRIBER_PASSWORD=TROQUE_O_TOKEN
