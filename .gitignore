# ==========================================
# Variáveis de Ambiente e Credenciais
# ==========================================
.env
.env.*
*.pem
*.key
!.env.example

# ==========================================
# Caches e Binários Python (FastAPI)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# Ambientes Virtuais Python
# ==========================================
.venv/
venv/
env/
ENV/
infra/api/venv/

# ==========================================
# Build e Artefatos C/C++ (ESP-IDF)
# ==========================================
firmware/build/
firmware/sdkconfig.old
firmware/managed_components/
firmware/dependencies.lock
.clangd/

# ==========================================
# Estado de Contêineres e Volumes (Docker)
# ==========================================
infra/mosquitto/data/*
!infra/mosquitto/data/.gitkeep
infra/mosquitto/log/*
!infra/mosquitto/log/.gitkeep

# ==========================================
# Configurações Específicas de IDE
# ==========================================
.vscode/settings.json
.vscode/c_cpp_properties.json
.idea/
*.swp

# ==========================================
# Arquivos de Sistema Operacional
# ==========================================
.DS_Store
Thumbs.db

